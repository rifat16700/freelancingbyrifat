# FN Pay Backend Configuration
# Copy this file to .env and fill in the values for local development.
# On Hugging Face Spaces, configure these in the Spaces Settings under Variables/Secrets.

# Express Configuration
PORT=7860
NODE_ENV=development

# Database Provider Selection (Explicitly choose 'supabase' or 'appwrite'. Defaults to auto-detecting based on provided credentials)
DB_PROVIDER=supabase

# Binance Pay API Credentials (Generate in the Binance Portal / API Management)
BINANCE_API_KEY=your_binance_api_key_here
# Can use BINANCE_SECRET_KEY or BINANCE_API_SECRET
BINANCE_SECRET_KEY=your_binance_secret_key_here

# --- DB Option 1: Supabase Configuration ---
SUPABASE_URL=https://your-project-id.supabase.co
# Use service_role key (trusted) to allow writing from the backend
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# --- DB Option 2: Appwrite Configuration ---
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT=your_appwrite_project_id_here
APPWRITE_API_KEY=your_appwrite_api_key_here
APPWRITE_DATABASE_ID=6a19e07f002427086405
APPWRITE_COLLECTION_VERIFIED_PAYMENTS=verified_payments
